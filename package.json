{
  "name": "bandhan-cafe",
  "version": "1.0.0",
  "description": "Bandhan Cafe - Full stack React and Express application",
  "main": "dist/server.js",
  "scripts": {
    "dev:server": "nodemon --watch src --ext ts,tsx --delay 250ms --exec ts-node src/index.ts",
    "dev:client": "webpack serve --config webpack.config.js --mode development --port 8080",
    "dev": "concurrently -k \"yarn dev:server\" \"yarn dev:client\"",
    "build:client": "webpack --config webpack.config.js --mode production",
    "build:server": "tsc",
    "build": "yarn build:client && yarn build:server",
    "start": "NODE_ENV=production node dist/index.js",
    "seed": "ts-node src/server/scripts/seed.ts",
    "clean": "rm -rf dist public",
    "type-check": "tsc --noEmit",
    "lint": "echo 'Add linting script here'",
    "test": "echo 'Add testing script here'"
  },
  "keywords": [
    "cafe",
    "react",
    "express",
    "typescript",
    "fullstack"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.104.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.22.1",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "path": "^0.12.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "7.14.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.9",
    "@babel/preset-env": "^7.23.9",
    "@babel/preset-react": "^7.23.9",
    "@babel/preset-typescript": "^7.23.9",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.6",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "babel-loader": "^9.1.3",
    "concurrently": "^8.2.2",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^6.8.1",
    "html-webpack-plugin": "^5.6.0",
    "nodemon": "^3.0.3",
    "style-loader": "^3.3.3",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  }
}
